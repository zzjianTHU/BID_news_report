{
  "name": "bid-news-report",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --env-file=.env --import tsx scripts/dev.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "doctor:runtime": "node --env-file=.env scripts/doctor.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node --env-file=.env --import tsx prisma/seed.ts",
    "db:reset": "node -e \"if (process.env.ALLOW_DATABASE_RESET !== 'true') { console.error('Set ALLOW_DATABASE_RESET=true before running db:reset.'); process.exit(1); }\" && prisma db push --force-reset && npm run db:seed",
    "worker:sync-feishu-sources": "node --env-file=.env --import tsx scripts/worker.ts sync-feishu-sources",
    "worker:sync-feishu-control-plane": "node --env-file=.env --import tsx scripts/worker.ts sync-feishu-control-plane",
    "worker:run-ingest-cycle": "node --env-file=.env --import tsx scripts/worker.ts run-ingest-cycle",
    "worker:sync-feishu-draft-decisions": "node --env-file=.env --import tsx scripts/worker.ts sync-feishu-draft-decisions",
    "worker:generate-digest": "node --env-file=.env --import tsx scripts/worker.ts generate-digest",
    "worker:dispatch-email": "node --env-file=.env --import tsx scripts/worker.ts dispatch-email",
    "content:regenerate": "node --env-file=.env --import tsx scripts/regenerate-content.ts",
    "scheduler:apply": "node --env-file=.env --import tsx scripts/sync-local-scheduler.ts apply",
    "scheduler:remove": "node --env-file=.env --import tsx scripts/sync-local-scheduler.ts remove",
    "automation:run": "npm run worker:run-ingest-cycle"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "cheerio": "^1.0.0",
    "date-fns": "^4.1.0",
    "next": "^15.2.2",
    "openai": "^4.89.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "rss-parser": "^3.13.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.11",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.2",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
