generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  EDITOR
}

enum SourceType {
  RSS
  WEB
}

enum RunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum IngestionTrigger {
  SCHEDULED
  MANUAL_SYNC
}

enum RiskLevel {
  LOW
  HIGH
}

enum CandidateStatus {
  INGESTED
  REVIEW
  PUBLISHED
  REJECTED
}

enum AutoPostStatus {
  PUBLISHED
  REVIEW
}

enum DigestDuration {
  THREE
  EIGHT
}

enum ThoughtStatus {
  DRAFT
  PUBLISHED
}

enum DispatchStatus {
  PENDING
  SENT
  FAILED
}

enum ModelProvider {
  OPENAI
  OPENAI_COMPATIBLE
  ANTHROPIC
  GEMINI
}

enum DraftStatus {
  AUTO_PUBLISHED
  PENDING_REVIEW
  APPROVED
  REJECTED
  NEEDS_REWRITE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      UserRole
  topic     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Source {
  id             String         @id @default(cuid())
  feishuRecordId String?        @unique
  name           String
  slug           String         @unique
  type           SourceType
  url            String
  description    String
  frequency      String
  fetchIntervalMinutes Int      @default(60)
  priority       Int            @default(50)
  trustScore     Int            @default(70)
  enabled        Boolean        @default(true)
  tags           String
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  failureCount   Int            @default(0)
  lastError      String?
  lockedAt       DateTime?
  lastSyncedAt   DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  candidateItems CandidateItem[]
  ingestionRuns  IngestionRun[]
}

model WorkflowConfig {
  id                 String   @id @default(cuid())
  feishuRecordId      String?  @unique
  name               String   @unique
  version            String   @default("v1")
  summaryPrompt      String
  highlightPrompt    String
  classificationPrompt String @default("")
  structuringPrompt  String   @default("")
  detailMarkdownPrompt String @default("")
  riskKeywords       String
  autoPublishMinTrust Int
  autoPublishMinQuality Float @default(0.75)
  digestRuleThree    String
  digestRuleEight    String
  digestThreePrompt  String   @default("")
  digestEightPrompt  String   @default("")
  classificationRouteKey String?
  structuringRouteKey String?
  detailMarkdownRouteKey String?
  digestThreeRouteKey String?
  digestEightRouteKey String?
  notes              String?
  active             Boolean  @default(true)
  lastSyncedAt       DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ModelRouteConfig {
  id            String        @id @default(cuid())
  feishuRecordId String?      @unique
  routeKey      String        @unique
  enabled       Boolean       @default(true)
  provider      ModelProvider
  baseUrl       String?
  model         String
  apiKeyEnvName String
  temperature   Float         @default(0.2)
  maxTokens     Int           @default(2000)
  timeoutMs     Int           @default(30000)
  notes         String?
  lastSyncedAt  DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model IngestionRun {
  id             String      @id @default(cuid())
  sourceId       String?
  source         Source?     @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  trigger        IngestionTrigger @default(SCHEDULED)
  status         RunStatus
  itemsFound     Int
  itemsPublished Int
  notes          String?
  errorSummary   String?
  startedAt      DateTime
  finishedAt     DateTime?
  createdAt      DateTime    @default(now())
  candidateItems CandidateItem[]
}

model CandidateItem {
  id             String          @id @default(cuid())
  sourceId       String
  source         Source          @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  ingestionRunId String?
  ingestionRun   IngestionRun?   @relation(fields: [ingestionRunId], references: [id], onDelete: SetNull)
  title          String
  normalizedUrl  String          @unique
  excerpt        String
  rawContent     String
  tags           String
  coverImageUrl  String?
  coverImageAlt  String?
  aiSummary      String
  worthReading   String
  aiConfidence   Float           @default(0.7)
  workflowVersion String?
  qualityScore   Float           @default(0)
  classificationJson Json?
  structuredJson Json?
  draftMarkdown  String?
  feishuDraftRecordId String?    @unique
  draftStatus    DraftStatus     @default(PENDING_REVIEW)
  editorNotes    String?
  riskLevel      RiskLevel
  status         CandidateStatus @default(INGESTED)
  reviewRequestedAt DateTime?
  reviewMessageId String?
  reviewDecisionBy String?
  reviewDecisionAt DateTime?
  publishedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  autoPost       AutoPost?
}

model AutoPost {
  id              String         @id @default(cuid())
  candidateItemId String         @unique
  candidateItem   CandidateItem  @relation(fields: [candidateItemId], references: [id], onDelete: Cascade)
  slug            String?        @unique
  title           String
  summary         String
  worthReading    String
  body            String
  bodyMarkdown    String?
  tldr            Json?
  workflowVersion String?
  qualityScore    Float          @default(0)
  tags            String
  sourceLabel     String
  sourceUrl       String
  status          AutoPostStatus
  publishedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Digest {
  id        String        @id @default(cuid())
  date      String        @unique
  title     String
  summary   String
  entries   DigestEntry[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  dispatches EmailDispatch[]
}

model DigestEntry {
  id           String         @id @default(cuid())
  digestId     String
  digest       Digest         @relation(fields: [digestId], references: [id], onDelete: Cascade)
  duration     DigestDuration
  order        Int
  title        String
  summary      String
  worthReading String
  sourceLabel  String
  sourceUrl    String
  tag          String
  postSlug     String?
}

model ThoughtPost {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  excerpt     String
  body        String
  authorName  String
  status      ThoughtStatus
  publishedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Subscriber {
  id              String          @id @default(cuid())
  email           String          @unique
  name            String?
  interest        String
  defaultDuration DigestDuration
  frequency       String
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  dispatches      EmailDispatch[]
}

model EmailDispatch {
  id           String         @id @default(cuid())
  subscriberId String
  subscriber   Subscriber     @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  digestId     String
  digest       Digest         @relation(fields: [digestId], references: [id], onDelete: Cascade)
  status       DispatchStatus
  subject      String
  scheduledFor DateTime
  sentAt       DateTime?
  notes        String?
  createdAt    DateTime       @default(now())
}
